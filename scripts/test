#!/bin/sh
#shellcheck disable=disable=SC2086

set -e

echo 'This might take a while...'

PATH_TEST=../tests

CFLAGS="
-std=c99
-Wall
-Wextra
-Wpedantic
-O2
-g
-fsanitize=address
$CFLAGS
"

has_prog()
{
	type "$1" >/dev/null 2>/dev/null
}

cd "$(dirname "$0")" || exit

# Set the path to compile and run the tests to.
if [ -z "$TMPDIR" ]; then
	if [ -d /tmp ]; then
		TMPDIR=/tmp
	else
		TMPDIR=$(echo "$PWD" | head -c 255)
	fi
fi
TMP_TESTDIR="$TMPDIR"/$(echo "$PWD" | sed 's/\///g; s/\.//g')
mkdir "$TMP_TESTDIR" || exit

# Test all files in arguments. Otherwise, test all.
if [ $# -eq 0 ]; then
	files=$(echo $PATH_TEST/*.c)
else
	files=$(echo "$*" | sed 's/ /\n/g')
fi

tests()
{
	TMP_TESTDIR=$1
	shift
	for file in $files; do
		# echo nice -n 19 ./test1 $TMP_TESTDIR $file $@
		nice -n 19 ./test1 $TMP_TESTDIR $file $@ &
	done
}

# Tests
if command -v parallel >/dev/null && parallel --version | grep -F 'GNU' | grep -q '^/'; then
	# Fast tests
	printf '%s\n' $files | parallel ./test1 "$TMP_TESTDIR" {} $CFLAGS
	printf '%s\n' $files | parallel ./test1 "$TMP_TESTDIR" {} $CFLAGS -march=native
	# Slow tests
	printf '%s\n' $files | parallel ./test1 "$TMP_TESTDIR" {} $CFLAGS -DJSTR_TEST_SLOW=1
	printf '%s\n' $files | parallel ./test1 "$TMP_TESTDIR" {} $CFLAGS -DJSTR_TEST_SLOW=1 -march=native
else
	# Fast tests
	tests "$TMP_TESTDIR" $CFLAGS
	tests "$TMP_TESTDIR" $CFLAGS -march=native
	wait
	# Slow tests
	tests "$TMP_TESTDIR" $CFLAGS -DJSTR_TEST_SLOW=1
	tests "$TMP_TESTDIR" $CFLAGS -DJSTR_TEST_SLOW=1 -march=native
	wait
fi

rmdir "$TMP_TESTDIR"

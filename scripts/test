#!/bin/sh
#shellcheck disable=disable=SC2086

set -e

echo 'This might take a while...'

PATH_TEST=../tests

CFLAGS="
-std=c99
-Wall
-Wextra
-Wpedantic
-O2
-g
-fsanitize=address
-D_XOPEN_SOURCE=700
$CFLAGS
"
# Flatten newlines to single spaces
CFLAGS=$(echo "$CFLAGS" | tr '\n' ' ' | sed 's/  */ /g; s/^ *//; s/ *$//')

cd "$(dirname "$0")" || exit

# Build shared library for test linkage
echo 'Building shared library...'
CFLAGS="$CFLAGS -DJSTR_DEBUG=1" ./build-library

# Set the path to compile and run the tests to.
if [ -z "$TMPDIR" ]; then
	if [ -d /tmp ]; then
		TMPDIR=/tmp
	else
		TMPDIR=$(echo "$PWD" | head -c 255)
	fi
fi
TMP_TESTDIR="$TMPDIR"/$(echo "$PWD" | sed 's/\///g; s/\.//g')
mkdir -p "$TMP_TESTDIR"

# Test all files in arguments. Otherwise, test all.
if [ $# -eq 0 ]; then
	files=$(echo $PATH_TEST/*.c)
else
	files=$(echo "$*" | sed 's/ /\n/g')
fi

NPROC=$(nproc 2>/dev/null || sysctl -n hw.logicalcpu 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || echo '1')

# Generate all variant jobs and run them in a single parallel pool.
# Each job is: ./test1 <tmpdir> <file> <cflags...>
generate_jobs()
{
	for file in $files; do
		echo "$file $CFLAGS"
		echo "$file $CFLAGS -march=native"
		echo "$file $CFLAGS -DJSTR_TEST_SLOW=1"
		echo "$file $CFLAGS -DJSTR_TEST_SLOW=1 -march=native"
	done
}

generate_jobs | xargs -P "$NPROC" -L 1 ./test1 "$TMP_TESTDIR"

# Remove stale executables but keep .o files for caching across runs
find "$TMP_TESTDIR" -type f ! -name '*.o' -delete 2>/dev/null
